{
  "name": "apexpulse",
  "version": "1.0.0",
  "description": "The Apex Legends tracker that actually works.",
  "main": "dist/main.js",
  "scripts": {
    "build": "webpack",
    "start": "ow-electron dist/main.js",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "author": "Campers Construction LLC",
  "license": "ISC",
  "dependencies": {
    "@overwolf/ow-electron": "^39.6.1",
    "axios": "^1.15.2",
    "better-sqlite3": "^12.9.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "recharts": "^3.8.1",
    "tesseract.js": "^7.0.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.0",
    "copy-webpack-plugin": "^14.0.0",
    "css-loader": "^7.1.4",
    "electron-builder": "^26.8.1",
    "html-webpack-plugin": "^5.6.7",
    "postcss": "^8.5.10",
    "postcss-loader": "^8.2.1",
    "style-loader": "^4.0.0",
    "tailwindcss": "^4.2.4",
    "ts-loader": "^9.5.7",
    "typescript": "^6.0.3",
    "webpack": "^5.106.2",
    "webpack-cli": "^7.0.2"
  },
  "build": {
    "appId": "com.campersconstruction.apexpulse",
    "productName": "ApexPulse",
    "files": [
      "dist/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icons/icon.png"
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false
    }
  }
}
